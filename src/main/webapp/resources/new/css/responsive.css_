    cursor: pointer;
    display: block;
    font-size: 14px;
}

.w-btnArea .wBtn02 {
    width: 95px;
    height: 35px;
    line-height: 35px;
    border-radius: 5px;
    text-align: center;
    background: #077b9c;
    color: #fff;
    border: 1px solid #077b9c;
    cursor: pointer;
