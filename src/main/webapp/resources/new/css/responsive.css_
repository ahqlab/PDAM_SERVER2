    -ms-flex-pack: center;
    -webkit-justify-content: center;
    justify-content: center;
    margin-top: 50px;
}

.w-btnArea .wBtn01 {
    width: 95px;
    height: 35px;
    line-height: 35px;
    border-radius: 5px;
    text-align: center;
    background: #8691a7;
